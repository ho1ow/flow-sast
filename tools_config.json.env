{
  "_comment": "Copy this file to tools_config.json and fill in values. Never commit tools_config.json.",

  "anthropic": {
    "api_key": "YOUR_ANTHROPIC_API_KEY",
    "model": "claude-sonnet-4-5",
    "max_tokens": 4096,
    "temperature": 0.1,
    "max_concurrency": 3
  },

  "joern": {
    "base_url": "http://localhost:8080",
    "timeout_seconds": 300,
    "cpg_build_timeout": 600,
    "retry_attempts": 3
  },

  "gitnexus": {
    "binary": "gitnexus",
    "timeout_seconds": 120,
    "extra_args": []
  },

  "semgrep": {
    "configs": ["auto", "p/security-audit", "p/owasp-top-ten"],
    "custom_rules_dir": "phases/1_catalog/rules",
    "timeout_seconds": 300,
    "max_memory_mb": 2048,
    "jobs": 4
  },

  "burp_mcp": {
    "base_url": "http://localhost:1337",
    "api_key": "YOUR_BURP_MCP_API_KEY",
    "timeout_seconds": 60,
    "follow_redirects": true
  },

  "pipeline": {
    "triage_min_score": 6,
    "verify_max_retries": 2,
    "checkpoint_dir": "pentest_logs/checkpoints",
    "audit_dir": "pentest_logs/audit_trail",
    "output_dir": "pentest_logs/output",
    "code_context_lines": 50
  }
}
