# Environment variables — SECRETS
# Copy file này thành .env và điền giá trị thật
# .env được gitignore — KHÔNG bao giờ commit .env

# ── Anthropic / Claude ────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-YOUR_KEY_HERE

# ── Burp Suite MCP ────────────────────────────────────────────────────────────
BURP_MCP_API_KEY=YOUR_BURP_MCP_KEY_HERE
BURP_MCP_BASE_URL=http://localhost:1337

# ── Joern REST server ─────────────────────────────────────────────────────────
JOERN_BASE_URL=http://localhost:8080

# ── GitNexus ─────────────────────────────────────────────────────────────────
# Binary path nếu không trong PATH
# GITNEXUS_BINARY=/usr/local/bin/gitnexus
